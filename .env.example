# Database Configuration
# MongoDB connection string (replace with your production database)
DATABASE_URI=mongodb+srv://username:password@your-cluster.mongodb.net/your-database

# Payload CMS Secret
# Generate a secure random string for production (minimum 32 characters)
PAYLOAD_SECRET=your-secure-payload-secret-min-32-characters

# Server URL
# Update to your production domain (e.g., https://yourdomain.com)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Email Configuration (Option 1: Resend)
# Uncomment to use Resend email service
# RESEND_API_KEY=re_your_resend_api_key
# E_MAIL=your-email@yourdomain.com
# COMPANY_NAME=Your Company Name

# Email Configuration (Option 2: SMTP - Office 365 / Outlook)
# Uncomment and configure to use SMTP (Office 365, Gmail, etc.)
SMTP_HOST=smtp.office365.com
SMTP_USER=your-email@yourdomain.com
SMTP_PASS=your-smtp-app-password

# Vercel Blob Storage
# Get your token from Vercel dashboard
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your_token_here
